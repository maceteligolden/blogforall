# Server Configuration
PORT=3001
NODE_ENV=development

# Public API base URL (image URLs, etc.). Defaults to http://localhost:${PORT} in ImageController when unset.
# BACKEND_URL=https://api.example.com

# File uploads (multer + static /uploads when object storage is disabled)
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=5242880

# Backblaze B2 (S3-compatible API) — set all five to use server-side uploads + public CDN URLs
# B2_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_BUCKET=your-bucket-name
# B2_KEY_ID=
# B2_APPLICATION_KEY=
# PUBLIC_ASSET_BASE_URL=https://f004.backblazeb2.com/file/your-bucket-name
# Or your CDN origin, e.g. https://cdn.example.com (no trailing slash)
#
# Friendly URLs require the bucket to allow public reads. Either set the bucket to **Public** in the
# Backblaze B2 UI (Bucket Settings → File visibility), or opt in (dev only if you understand the risk):
# B2_APPLY_BUCKET_PUBLIC_READ=true
# (runs PutBucketAcl public-read at startup; application key must include bucket ACL permissions)

# Database
MONGODB_URI=mongodb://localhost:27017/blogforall

# JWT Secrets (Generate strong random strings for production)
ACCESS_SECRET=your_access_secret_key_here_change_in_production_min_32_chars
REFRESH_SECRET=your_refresh_secret_key_here_change_in_production_min_32_chars

# Frontend URL (for CORS) - Can be comma-separated for multiple origins
# Example: http://localhost:3000,http://localhost:3002
FRONTEND_URL=http://localhost:3000,http://localhost:3002

# Stripe (billing + webhooks)
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional SMTP (legacy / fallback; Brevo is used for transactional mail when configured)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# Workspace API keys (32+ char key recommended; falls back to ACCESS_SECRET-derived key if unset)
# WORKSPACE_API_KEY_ENCRYPTION_KEY=

# Post scheduler (cron expression)
# SCHEDULER_INTERVAL=*/1 * * * *

# Blog Review (Hugging Face Inference). Token must have "Inference" permission.
# Create at https://huggingface.co/settings/tokens (fine-grained: Inference > serverless Inference API)
HUGGINGFACE_API_TOKEN=
# Optional HF alias for review/agent
# HF_TOKEN=
# Optional: model for review (default: Qwen/Qwen2.5-7B-Instruct)
# BLOG_REVIEW_MODEL=Qwen/Qwen2.5-7B-Instruct

# Blog generation / campaign agent (optional overrides — see shared/config/env.ts defaults)
# BLOG_GENERATION_MODEL=
# CAMPAIGN_AGENT_MODEL=

# Workspace (Site) defaults
WORKSPACE_DEFAULT_NAME=My Workspace
INVITATION_EXPIRY_DAYS=7

# Notification service (Brevo + in-process queue)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@bloggr.com
BREVO_SENDER_NAME=Bloggr
REDIS_URL=redis://localhost:6379
NOTIFICATION_RETENTION_DAYS_READ=90
EMAIL_METADATA_RETENTION_DAYS=365
EMAIL_QUEUE_NAME=notification:email
