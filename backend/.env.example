# Server Configuration
PORT=3001
NODE_ENV=development

# Public API base URL (image URLs, etc.). Defaults to http://localhost:${PORT} in ImageController when unset.
# BACKEND_URL=https://api.example.com

# File uploads (multer + static /uploads)
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=5242880

# Database
MONGODB_URI=mongodb://localhost:27017/blogforall

# JWT Secrets (Generate strong random strings for production)
ACCESS_SECRET=your_access_secret_key_here_change_in_production_min_32_chars
REFRESH_SECRET=your_refresh_secret_key_here_change_in_production_min_32_chars

# Frontend URL (for CORS) - Can be comma-separated for multiple origins
# Example: http://localhost:3000,http://localhost:3002
FRONTEND_URL=http://localhost:3000,http://localhost:3002

# Stripe (billing + webhooks)
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional SMTP (legacy / fallback; Brevo is used for transactional mail when configured)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# Workspace API keys (32+ char key recommended; falls back to ACCESS_SECRET-derived key if unset)
# WORKSPACE_API_KEY_ENCRYPTION_KEY=

# Post scheduler (cron expression)
# SCHEDULER_INTERVAL=*/1 * * * *

# Blog generation (LangGraph + OpenAI). Reuses OPENAI_API_KEY when set.
# BLOG_AI_OPENAI_API_KEY=
# BLOG_AI_CHAT_MODEL=gpt-4o-mini
# BLOG_AI_REVIEW_MODEL=gpt-4o-mini
# TAVILY_API_KEY=

# Workspace Orchestrator Agent (LangGraph supervisor + DB-backed memory).
# Reuses OPENAI_API_KEY / BLOG_AI_OPENAI_API_KEY when ORCHESTRATOR_OPENAI_API_KEY is unset.
# ORCHESTRATOR_OPENAI_API_KEY=
# ORCHESTRATOR_SUPERVISOR_MODEL=gpt-4o-mini
# ORCHESTRATOR_MEMORY_DIGEST_MODEL=gpt-4o-mini
# ORCHESTRATOR_API_TIMEOUT=120000
# ORCHESTRATOR_MAX_THREAD_MESSAGES=80
# Nightly memory digest cron (default 04:00 server local).
# ORCHESTRATOR_MEMORY_DIGEST_CRON=0 4 * * *
# Hours of orchestrator transcript to fold into workspace memory (default 48).
# ORCHESTRATOR_MEMORY_DIGEST_LOOKBACK_HOURS=48
# Max workspaces processed per digest tick (default 200).
# ORCHESTRATOR_MEMORY_DIGEST_MAX_SITES=200
# Hours before scheduled_at to prepare draft and request human approval.
# ORCHESTRATOR_REVIEW_LEAD_TIME_HOURS=72
# Signed review-token TTL (days). Tokens are sent in approval emails.
# ORCHESTRATOR_REVIEW_TOKEN_TTL_DAYS=14
# Weekly publishing digest cron (default: Mondays 09:00).
# ORCHESTRATOR_WEEKLY_DIGEST_CRON=0 9 * * 1
# Milliseconds before a pending in-chat confirmation auto-rejects.
# ORCHESTRATOR_CONFIRM_TIMEOUT_MS=600000
# Max rework rounds per scheduled post before manual editing is required.
# ORCHESTRATOR_MAX_REWORK_ROUNDS=5
# Optional: dedicated secret for signing review tokens (falls back to ACCESS_SECRET).
# ORCHESTRATOR_REVIEW_TOKEN_SECRET=

# Workspace (Site) defaults
WORKSPACE_DEFAULT_NAME=My Workspace
INVITATION_EXPIRY_DAYS=7

# Notification service (Brevo + in-process queue)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@bloggr.com
BREVO_SENDER_NAME=Bloggr
REDIS_URL=redis://localhost:6379
NOTIFICATION_RETENTION_DAYS_READ=90
EMAIL_METADATA_RETENTION_DAYS=365
EMAIL_QUEUE_NAME=notification:email
