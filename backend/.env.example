# Server Configuration
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/blogforall

# JWT Secrets (Generate strong random strings for production)
ACCESS_SECRET=your_access_secret_key_here_change_in_production_min_32_chars
REFRESH_SECRET=your_refresh_secret_key_here_change_in_production_min_32_chars

# Frontend URL (for CORS) - Can be comma-separated for multiple origins
# Example: http://localhost:3000,http://localhost:3002
FRONTEND_URL=http://localhost:3000,http://localhost:3002

# Blog Review (Hugging Face Inference). Token must have "Inference" permission.
# Create at https://huggingface.co/settings/tokens (fine-grained: Inference > serverless Inference API)
HUGGINGFACE_API_TOKEN=
# Optional: model for review (default: Qwen/Qwen2.5-7B-Instruct)
# BLOG_REVIEW_MODEL=Qwen/Qwen2.5-7B-Instruct

# Workspace (Site) defaults
WORKSPACE_DEFAULT_NAME=My Workspace
INVITATION_EXPIRY_DAYS=7

# Notification service (Brevo + in-process queue)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@blogforall.com
BREVO_SENDER_NAME=BlogForAll
REDIS_URL=redis://localhost:6379
NOTIFICATION_RETENTION_DAYS_READ=90
EMAIL_METADATA_RETENTION_DAYS=365
EMAIL_QUEUE_NAME=notification:email
